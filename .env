# Environment variables for development/sandbox
# These are safe defaults that allow the app to run without external services

# Supabase (leave empty for offline/sandbox mode)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# API Base (leave empty for same-origin)
VITE_API_BASE=

# Turnstile CAPTCHA (leave empty to disable)
VITE_TURNSTILE_SITE_KEY=
